OKX_RPC_URL="https://rpc.xlayer.tech"

# 3. Social & Identity Resolvers
TWITTER_BEARER_TOKEN="your-twitter-v2-api-token"
ENS_GRAPHQL_ENDPOINT="https://api.thegraph.com/subgraphs/name/ensdomains/ens"
