# 1. AI Intent Engine (OpenClaw / OpenAI)
LLM_API_KEY="sk-your-openai-or-claw-key-here"
LLM_MODEL_VERSION="gpt-5.4-turbo"

# 2. OKX Onchain OS Data Layer
# Register at: https://www.okx.com/web3/build
OKX_API_KEY="your-okx-developer-api-key"
OKX_SECRET_KEY="your-okx-secret-key"
